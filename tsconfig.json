{
	"compilerOptions": {
		"lib": ["ESNext"],
		"target": "ES2022",
		"module": "NodeNext",
		"moduleDetection": "force",
		"types": ["node"],

		/* Bundler mode */
		"moduleResolution": "NodeNext",
		/* Linting */
		"skipLibCheck": true,
		"strict": true,
		"noFallthroughCasesInSwitch": true,
		"forceConsistentCasingInFileNames": true,

		"composite": true
	}
}
